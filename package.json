{
  "name": "agentinel",
  "version": "1.0.3",
  "description": "Catches AI hallucinated npm packages before an agent installs them",
  "license": "MIT",
  "author": "Aman Janwani",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aman-janwani/agentinel.git"
  },
  "bugs": {
    "url": "https://github.com/aman-janwani/agentinel/issues"
  },
  "homepage": "https://github.com/aman-janwani/agentinel#readme",
  "bin": {
    "asen": "./dist/asen.js",
    "agentinel": "./dist/asen.js"
  },
  "files": [
    "dist",
    "data"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "build:malware": "node scripts/build-malware-list.mjs"
  },
  "keywords": [
    "claude-code",
    "ai-agent",
    "security",
    "npm",
    "supply-chain",
    "slopsquatting",
    "cli"
  ],
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsup": "^8.5.1",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10"
  }
}
