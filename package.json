{
  "name": "agentsentinel",
  "version": "0.1.0",
  "description": "Catches AI hallucinated npm packages before an agent installs them",
  "license": "MIT",
  "author": "Aman Janwani",
  "type": "module",
  "bin": {
    "asen": "./dist/asen.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude-code",
    "ai-agent",
    "security",
    "npm",
    "supply-chain",
    "slopsquatting",
    "cli"
  ],
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
